<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="45dp"
                android:centerX="0.35"
                android:centerY="0.3"
                android:startColor="#34405C"
                android:endColor="#121A2C" />
            <stroke android:width="2.5dp" android:color="#2E3A54" />
        </shape>
    </item>
</layer-list>
