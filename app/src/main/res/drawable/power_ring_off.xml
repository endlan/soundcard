<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Ring titik-titik di luar (dekoratif, kayak knob analog fisik) -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="#3A4560"
                android:dashWidth="4dp"
                android:dashGap="4dp" />
        </shape>
    </item>
    <!-- Badan knob metalik -->
    <item android:left="9dp" android:top="9dp" android:right="9dp" android:bottom="9dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="45dp"
                android:centerX="0.35"
                android:centerY="0.3"
                android:startColor="#3E4A68"
                android:endColor="#12182A" />
            <stroke android:width="2dp" android:color="#2E3A54" />
        </shape>
    </item>
</layer-list>
