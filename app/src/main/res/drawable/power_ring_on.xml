<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="45dp"
                android:centerX="0.35"
                android:centerY="0.3"
                android:startColor="#3A4054"
                android:endColor="#12151D" />
            <stroke android:width="2.5dp" android:color="@color/power_on" />
        </shape>
    </item>
</layer-list>
